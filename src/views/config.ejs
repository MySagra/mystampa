  <!-- Content -->
  <div class="content">
    <!-- Printers -->
    <div class="settings-card">
      <div class="card-header">
        <div class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            class="lucide lucide-printer-icon lucide-printer">
            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
            <path d="M6 9V3a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v6" />
            <rect x="6" y="14" width="12" height="8" rx="1" />
          </svg>
        </div>
        <span class="card-title">Stampanti</span>
      </div>
      <p class="card-description">Stato in tempo reale delle stampanti. Aggiornamento automatico ogni 2 minuti.</p>

      <div id="printersContainer">
        <div class="loading">
          <div class="spinner"></div>
          Caricamento stampanti...
        </div>
      </div>
      <div class="last-updated" id="printersUpdatedAt" style="display:none;"></div>
    </div>

    <!-- Single Ticket Categories -->
    <div class="settings-card">
      <div class="card-header">
        <div class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"
            stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
          </svg>
        </div>
        <span class="card-title">Categorie con Ticket Singolo</span>
      </div>
      <p class="card-description">Seleziona le categorie per le quali stampare un ticket singolo per ogni articolo</p>

      <div id="categoriesContainer">
        <div class="loading">
          <div class="spinner"></div>
          Caricamento categorie...
        </div>
      </div>
    </div>

    <!-- Station Tickets -->
    <div class="settings-card">
      <div class="card-header">
        <div class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"
            stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <span class="card-title">Tagliandini per Postazione di Ritiro</span>
      </div>
      <p class="card-description">Se attivo, stampa un tagliandino di ritiro per ogni postazione allegato allo scontrino</p>

      <label style="display:flex;align-items:center;gap:0.75rem;cursor:pointer;padding:0.5rem 0;">
        <div class="checkbox-wrapper" style="margin:0;">
          <input type="checkbox" id="stationTicketsToggle" onchange="onStationToggleChange()">
        </div>
        <span style="font-size:0.9rem;font-weight:500;">Abilita tagliandini postazione</span>
      </label>
    </div>

    <div class="save-bar" id="saveBar" style="display:none;">
      <button class="btn btn-save" id="saveBtn" onclick="saveConfig()">Salva modifiche</button>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast"></div>

  <script>
    /* ───── Printers ───── */
    var printersRefreshInterval = null;

    function statusClass(s) {
      if (!s) return 'unknown';
      switch (s.toUpperCase()) {
        case 'ONLINE': return 'online';
        case 'OFFLINE': return 'offline';
        case 'ERROR': return 'error';
        default: return 'unknown';
      }
    }

    function statusLabel(s) {
      if (!s) return 'Sconosciuto';
      switch (s.toUpperCase()) {
        case 'ONLINE': return 'Online';
        case 'OFFLINE': return 'Offline';
        case 'ERROR': return 'Errore';
        default: return s;
      }
    }

    function renderPrinters(list) {
      var container = document.getElementById('printersContainer');
      if (!list || list.length === 0) {
        container.innerHTML = '<div class="loading">Nessuna stampante configurata</div>';
        return;
      }
      var html = '<table class="category-table"><thead><tr>';
      html += '<th>Nome</th>';
      html += '<th>IP : Porta</th>';
      html += '<th>Descrizione</th>';
      html += '<th style="text-align:center;">Stato</th>';
      html += '</tr></thead><tbody>';
      for (var i = 0; i < list.length; i++) {
        var p = list[i];
        var sc = statusClass(p.status);
        var sl = statusLabel(p.status);
        html += '<tr>';
        html += '<td><div class="printer-name">' + escHtml(p.name) + '</div></td>';
        html += '<td><span class="printer-ip">' + escHtml(p.ip) + ':' + escHtml(String(p.port)) + '</span></td>';
        html += '<td>';
        if (p.description) {
          html += '<div class="printer-desc">' + escHtml(p.description) + '</div>';
        } else {
          html += '<span style="color:var(--text-muted);font-size:0.8rem;">—</span>';
        }
        html += '</td>';
        html += '<td style="text-align:center;"><span class="printer-status ' + sc + '">' + sl + '</span></td>';
        html += '</tr>';
      }
      html += '</tbody></table>';
      container.innerHTML = '<div class="table-scroll">' + html + '</div>';

      var now = new Date();
      var updatedEl = document.getElementById('printersUpdatedAt');
      updatedEl.style.display = 'block';
      updatedEl.textContent = 'Aggiornato alle ' + now.toLocaleTimeString('it-IT');
    }

    async function loadPrinters() {
      try {
        var resp = await fetch('/api/printers');
        if (resp.status === 401) { window.location.href = '/'; return; }
        var list = await resp.json();
        renderPrinters(list);
      } catch (err) {
        document.getElementById('printersContainer').innerHTML =
          '<div class="loading" style="color:#f87171;">Errore nel caricamento delle stampanti</div>';
        console.error(err);
      }
    }

    /* ───── Categories & Stations ───── */
    var categories = [];
    var selectedIds = [];
    var originalIds = [];

    var stationTicketsEnabled = false;

    function showToast(msg, type) {
      var t = document.getElementById('toast');
      t.textContent = msg;
      t.className = 'toast ' + type + ' show';
      setTimeout(function () { t.className = 'toast'; }, 3000);
    }

    function escHtml(s) {
      var d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    async function loadData() {
      try {
        var [catResp, configResp] = await Promise.all([
          fetch('/api/categories'),
          fetch('/api/config')
        ]);

        if (catResp.status === 401 || configResp.status === 401) {
          window.location.href = '/';
          return;
        }

        categories = await catResp.json();
        var config = await configResp.json();
        selectedIds = config.singleTicketCategories || [];
        originalIds = selectedIds.slice();
        stationTicketsEnabled = !!config.stationTicketsEnabled;

        categories.sort(function (a, b) { return (a.position || 0) - (b.position || 0); });

        renderTable();
        document.getElementById('stationTicketsToggle').checked = stationTicketsEnabled;
        document.getElementById('saveBar').style.display = 'flex';
      } catch (err) {
        document.getElementById('categoriesContainer').innerHTML =
          '<div class="loading" style="color:#f87171;">Errore nel caricamento delle categorie</div>';
        console.error(err);
      }
    }

    function renderTable() {
      if (categories.length === 0) {
        document.getElementById('categoriesContainer').innerHTML =
          '<div class="loading">Nessuna categoria trovata</div>';
        return;
      }

      var html = '<table class="category-table">';
      html += '<thead><tr>';
      html += '<th style="width:50px;text-align:center;">Ticket</th>';
      html += '<th>Categoria</th>';
      html += '<th style="width:100px;text-align:center;">Stato</th>';
      html += '</tr></thead><tbody>';

      for (var i = 0; i < categories.length; i++) {
        var cat = categories[i];
        var checked = selectedIds.indexOf(cat.id) !== -1 ? 'checked' : '';
        var availClass = cat.available ? 'yes' : 'no';
        var availText = cat.available ? 'Attiva' : 'Disattiva';

        html += '<tr>';
        html += '<td><div class="checkbox-wrapper"><input type="checkbox" data-id="' + cat.id + '" ' + checked + ' onchange="onCheckChange()"></div></td>';
        html += '<td><div class="cat-name">' + escHtml(cat.name) + '</div></td>';
        html += '<td style="text-align:center;"><span class="cat-available ' + availClass + '">' + availText + '</span></td>';
        html += '</tr>';
      }

      html += '</tbody></table>';
      document.getElementById('categoriesContainer').innerHTML = '<div class="table-scroll">' + html + '</div>';
    }

    function onCheckChange() {
      var checkboxes = document.querySelectorAll('#categoriesContainer input[type="checkbox"]');
      selectedIds = [];
      for (var i = 0; i < checkboxes.length; i++) {
        if (checkboxes[i].checked) selectedIds.push(checkboxes[i].getAttribute('data-id'));
      }
    }

    function onStationToggleChange() {
      stationTicketsEnabled = document.getElementById('stationTicketsToggle').checked;
    }

    async function saveConfig() {
      var btn = document.getElementById('saveBtn');
      btn.disabled = true;
      btn.textContent = 'Salvataggio...';

      try {
        var resp = await fetch('/api/config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            singleTicketCategories: selectedIds,
            stationTicketsEnabled: stationTicketsEnabled
          })
        });

        if (resp.ok) {
          originalIds = selectedIds.slice();
          showToast('Configurazione salvata con successo', 'success');
        } else {
          showToast('Errore nel salvataggio', 'error');
        }
      } catch (err) {
        showToast('Errore di connessione', 'error');
        console.error(err);
      } finally {
        btn.disabled = false;
        btn.textContent = 'Salva modifiche';
      }
    }

    loadData();
    loadPrinters();
    printersRefreshInterval = setInterval(loadPrinters, 10000);
  </script>
</body>

</html>