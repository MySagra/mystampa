<!DOCTYPE html>
<html lang="it">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MyStampa - Configurazione</title>
  <link rel="icon" type="image/x-icon" href="/public/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #18181b;
      --card-bg: #27272a;
      --header-bg: #1f1f23;
      --text: #fafafa;
      --text-muted: #a1a1aa;
      --primary: #eab308;
      --primary-hover: #ca8a04;
      --primary-fg: #422006;
      --border: rgba(255, 255, 255, 0.1);
      --input-border: rgba(255, 255, 255, 0.15);
      --success: #22c55e;
      --error: #ef4444;
      --radius: 0.625rem;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* Header */
    .header {
      background: var(--header-bg);
      border-bottom: 1px solid var(--border);
      padding: 0 1.5rem;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .header-logo {
      width: 48px;
      height: 48px;
      background: var(--primary);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .header-logo svg {
      width: 18px;
      height: 18px;
      fill: white;
    }

    .header-title {
      font-size: 1.1rem;
      font-weight: 600;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      border-radius: var(--radius);
      font-size: 0.85rem;
      font-weight: 500;
      font-family: inherit;
      cursor: pointer;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text);
      transition: background 0.15s ease, border-color 0.15s ease;
      user-select: none;
      text-decoration: none;
    }

    .btn:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(255, 255, 255, 0.2);
    }

    .btn svg {
      width: 16px;
      height: 16px;
    }

    /* Content */
    .content {
      max-width: 760px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    /* Settings card */
    .settings-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: calc(var(--radius) + 4px);
      padding: 1.75rem;
      margin-bottom: 1.5rem;
    }

    .card-header {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      margin-bottom: 0.25rem;
    }

    .card-icon {
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--primary);
    }

    .card-icon svg {
      width: 22px;
      height: 22px;
    }

    .card-title {
      font-size: 1rem;
      font-weight: 600;
    }

    .card-description {
      color: var(--text-muted);
      font-size: 0.85rem;
      margin-bottom: 1.25rem;
      padding-left: 38px;
    }

    /* Table */
    .category-table {
      width: 100%;
      border-collapse: collapse;
    }

    .category-table th {
      text-align: left;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 0.625rem 0.75rem;
      border-bottom: 1px solid var(--border);
    }

    .category-table td {
      padding: 0.75rem;
      border-bottom: 1px solid var(--border);
      font-size: 0.9rem;
    }

    .category-table tr:last-child td {
      border-bottom: none;
    }

    .category-table tr:hover td {
      background: rgba(255, 255, 255, 0.02);
    }

    /* Custom checkbox */
    .checkbox-wrapper {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .checkbox-wrapper input[type="checkbox"] {
      -webkit-appearance: none;
      appearance: none;
      width: 20px;
      height: 20px;
      border: 2px solid var(--input-border);
      border-radius: 5px;
      background: transparent;
      cursor: pointer;
      position: relative;
      transition: all 0.15s ease;
    }

    .checkbox-wrapper input[type="checkbox"]:checked {
      background: var(--primary);
      border-color: var(--primary);
    }

    .checkbox-wrapper input[type="checkbox"]:checked::after {
      content: '';
      position: absolute;
      left: 5px;
      top: 1px;
      width: 6px;
      height: 11px;
      border: solid var(--primary-fg);
      border-width: 0 2.5px 2.5px 0;
      transform: rotate(45deg);
    }

    .checkbox-wrapper input[type="checkbox"]:hover {
      border-color: var(--primary);
    }

    /* Save button */
    .save-bar {
      display: flex;
      justify-content: flex-end;
      margin-top: 1.25rem;
    }

    .btn-save {
      background: var(--primary);
      color: var(--primary-fg);
      border-color: var(--primary);
      font-weight: 600;
      padding: 0.6rem 1.5rem;
    }

    .btn-save:hover {
      background: var(--primary-hover);
      border-color: var(--primary-hover);
    }

    .btn-save:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      padding: 0.75rem 1.25rem;
      border-radius: var(--radius);
      font-size: 0.875rem;
      font-weight: 500;
      color: white;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.3s ease, transform 0.3s ease;
      z-index: 999;
      pointer-events: none;
    }

    .toast.show {
      opacity: 1;
      transform: translateY(0);
    }

    .toast.success {
      background: var(--success);
    }

    .toast.error {
      background: var(--error);
    }

    /* Loading */
    .loading {
      text-align: center;
      padding: 3rem;
      color: var(--text-muted);
    }

    .spinner {
      width: 32px;
      height: 32px;
      border: 3px solid var(--border);
      border-top-color: var(--primary);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 1rem;
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }

    /* Category name cell */
    .cat-name {
      font-weight: 500;
    }

    .cat-position {
      color: var(--text-muted);
      font-size: 0.8rem;
    }

    .cat-available {
      display: inline-block;
      padding: 0.15rem 0.5rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .cat-available.yes {
      background: rgba(34, 197, 94, 0.15);
      color: #4ade80;
    }

    .cat-available.no {
      background: rgba(239, 68, 68, 0.15);
      color: #f87171;
    }

    /* Printer status badges */
    .printer-status {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.2rem 0.65rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .printer-status::before {
      content: '';
      width: 7px;
      height: 7px;
      border-radius: 50%;
      display: inline-block;
    }

    .printer-status.online {
      background: rgba(34, 197, 94, 0.15);
      color: #4ade80;
    }

    .printer-status.online::before {
      background: #4ade80;
      box-shadow: 0 0 5px #4ade80;
    }

    .printer-status.offline {
      background: rgba(239, 68, 68, 0.15);
      color: #f87171;
    }

    .printer-status.offline::before {
      background: #f87171;
    }

    .printer-status.error {
      background: rgba(234, 179, 8, 0.15);
      color: #facc15;
    }

    .printer-status.error::before {
      background: #facc15;
    }

    .printer-status.unknown {
      background: rgba(161, 161, 170, 0.15);
      color: #a1a1aa;
    }

    .printer-status.unknown::before {
      background: #a1a1aa;
    }

    .printer-ip {
      font-family: 'Courier New', monospace;
      font-size: 0.82rem;
      color: var(--text-muted);
    }

    .printer-name {
      font-weight: 500;
    }

    .printer-desc {
      font-size: 0.8rem;
      color: var(--text-muted);
      margin-top: 0.1rem;
    }

    .last-updated {
      margin-top: 1rem;
      font-size: 0.78rem;
      color: var(--text-muted);
      text-align: right;
    }

    /* Table scroll wrapper */
    .table-scroll {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    /* ── Mobile responsive ── */
    @media (max-width: 600px) {
      .header {
        padding: 0 1rem;
      }

      .header-title {
        font-size: 0.95rem;
      }

      .content {
        padding: 1rem 0.75rem;
      }

      .settings-card {
        padding: 1.25rem 1rem;
        margin-bottom: 1rem;
      }

      .card-description {
        padding-left: 0;
        margin-top: 0.5rem;
      }

      .category-table th,
      .category-table td {
        padding: 0.6rem 0.5rem;
        font-size: 0.82rem;
      }

      .printer-ip {
        font-size: 0.75rem;
      }

      .toast {
        left: 1rem;
        right: 1rem;
        bottom: 1rem;
        text-align: center;
      }

      .save-bar {
        margin-top: 1rem;
      }

      .btn-save {
        width: 100%;
        justify-content: center;
      }

      .last-updated {
        text-align: left;
      }

      /* Nascondi colonna Descrizione stampanti su mobile */
      #printersContainer .category-table th:nth-child(3),
      #printersContainer .category-table td:nth-child(3) {
        display: none;
      }
    }
  </style>
</head>

