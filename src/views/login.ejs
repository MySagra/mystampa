<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MyStampa - Login</title>
  <link rel="icon" type="image/x-icon" href="/public/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #18181b;
      --card-bg: #27272a;
      --text: #fafafa;
      --text-muted: #a1a1aa;
      --primary: #eab308;
      --primary-hover: #ca8a04;
      --primary-fg: #422006;
      --border: rgba(255,255,255,0.1);
      --input-bg: transparent;
      --input-border: rgba(255,255,255,0.15);
      --input-focus: #eab308;
      --error-bg: rgba(239,68,68,0.1);
      --error-text: #f87171;
      --error-border: rgba(239,68,68,0.3);
      --radius: 0.625rem;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
    }

    .login-wrapper {
      width: 100%;
      max-width: 900px;
    }

    .login-card {
      background: var(--card-bg);
      border-radius: calc(var(--radius) + 4px);
      overflow: hidden;
      box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
      display: grid;
      grid-template-columns: 1fr;
    }

    @media (min-width: 768px) {
      .login-card {
        grid-template-columns: 1fr 1fr;
      }
    }

    .login-form-side {
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .login-image-side {
      display: none;
      overflow: hidden;
    }

    @media (min-width: 768px) {
      .login-image-side {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .login-form-side {
        padding: 3rem 2.5rem;
      }
    }

    .login-image-side img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      min-height: 500px;
    }

    /* Logo */
    .logo-icon {
      width: 120px;
      height: 120px;
      margin: 0 auto 1.5rem;
      background: var(--primary);
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .logo-icon svg {
      width: 44px;
      height: 44px;
      fill: white;
    }

    .login-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .login-header h1 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.375rem;
    }

    .login-header p {
      color: var(--text-muted);
      font-size: 0.875rem;
    }

    .field {
      margin-bottom: 1.25rem;
    }

    .field label {
      display: block;
      font-size: 0.875rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--text);
    }

    .input-group {
      position: relative;
      display: flex;
    }

    .input-group input {
      flex: 1;
      min-width: 0;
      padding: 0.625rem 0.875rem;
      border: 1px solid var(--input-border);
      border-radius: var(--radius);
      font-size: 0.875rem;
      font-family: inherit;
      background: var(--input-bg);
      color: var(--text);
      outline: none;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .input-group input::placeholder {
      color: var(--text-muted);
    }

    .input-group input:focus {
      border-color: var(--input-focus);
      box-shadow: 0 0 0 3px rgba(234, 179, 8, 0.15);
    }

    .input-group .toggle-password {
      flex-shrink: 0;
      width: 42px;
      background: none;
      border: 1px solid var(--input-border);
      border-left: none;
      border-radius: 0 var(--radius) var(--radius) 0;
      cursor: pointer;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.15s ease, background 0.15s ease;
    }

    .input-group .toggle-password:hover {
      color: var(--text);
      background: rgba(255,255,255,0.05);
    }

    .input-group.has-toggle input {
      border-top-right-radius: 0;
      border-bottom-right-radius: 0;
    }

    .error-message {
      background: var(--error-bg);
      color: var(--error-text);
      border: 1px solid var(--error-border);
      border-radius: var(--radius);
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      margin-bottom: 1.25rem;
      text-align: center;
    }

    .submit-btn {
      width: 100%;
      padding: 0.7rem 1rem;
      background: var(--primary);
      color: var(--primary-fg);
      border: 1px solid var(--primary);
      border-radius: var(--radius);
      font-size: 0.9rem;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      transition: background 0.15s ease, transform 0.1s ease;
      user-select: none;
    }

    .submit-btn:hover {
      background: var(--primary-hover);
      border-color: var(--primary-hover);
    }

    .submit-btn:active {
      transform: scale(0.98);
    }

    .submit-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .footer {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      text-align: center;
      padding: 1rem;
      font-size: 0.8rem;
      color: var(--text-muted);
      user-select: none;
    }

    .footer a {
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
    }

    .footer a:hover {
      text-decoration: underline;
    }

    .eye-icon { width: 16px; height: 16px; }
  </style>
</head>
<body>
  <div class="login-wrapper">
    <div class="login-card">
      <div class="login-form-side">
        <div class="login-header">
          <!-- Printer icon logo -->
          <div class="logo-icon" style="background: transparent;">
            <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 237" style="width: 100px; height: 100px; fill: none;">
